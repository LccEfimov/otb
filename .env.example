APP_NAME=TerraTesting
APP_ENV=production
APP_DEBUG=false
APP_LANGUAGE=ru

LOCAL_DB_ENABLED=true
LOCAL_DB_URL=sqlite:///./data/training_system.db

REMOTE_SYNC_ENABLED=false
REMOTE_DB_URL=mysql+pymysql://user:password@127.0.0.1:3306/terra_testing

# Sync trigger flags:
# SYNC_AFTER_LOGIN=false -> skip post-login sync attempt (reason=disabled_by_flag).
# SYNC_AFTER_TEST_COMPLETION=false -> keep result in local sync queue, skip immediate remote push (reason=disabled_by_flag).
# If REMOTE_SYNC_ENABLED=false or REMOTE_DB_URL is empty, reason=disabled.

QUESTIONS_PER_TEST=20
PASS_PERCENT=70
SECONDS_PER_QUESTION=30
MAX_ATTEMPTS=3

EXPORT_DIR=./data/exports
BACKUP_DIR=./data/backup
LOG_DIR=./logs

SEED_ADMIN_LOGIN=admin
SEED_ADMIN_PASSWORD=Admin123!
SEED_USER_LOGIN=user01
SEED_USER_PASSWORD=User123!

SYNC_RETRY_LIMIT=3
SYNC_AFTER_LOGIN=true
SYNC_AFTER_TEST_COMPLETION=true
